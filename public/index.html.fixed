<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DentaFlow — Gestión Clínica</title>
<meta name="description" content="Panel de gestión clínica con IA integrada para WhatsApp">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<script src="/exceljs.min.js"></script>
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>Ã°Å¸Â¦·</text></svg>">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-primary: #ffffff;
    --bg-secondary: #f5f5f3;
    --bg-tertiary: #eeede9;
    --text-primary: #1a1a18;
    --text-secondary: #6b6b67;
    --text-tertiary: #9b9b97;
    --border: rgba(0,0,0,0.12);
    --border-hover: rgba(0,0,0,0.22);
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
    --blue-bg: #e6f1fb; --blue-text: #185fa5; --blue-border: #b5d4f4; --blue-mid: #378add;
    --green-bg: #eaf3de; --green-text: #3b6d11; --green-border: #c0dd97;
    --red-bg: #fcebeb; --red-text: #a32d2d; --red-border: #f7c1c1;
    --amber-bg: #faeeda; --amber-text: #854f0b; --amber-border: #fac775;
    --teal-bg: #e1f5ee; --teal-text: #0f6e56; --teal-border: #9fe1cb;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg-primary: #1c1c1a;
      --bg-secondary: #252523;
      --bg-tertiary: #2e2e2b;
      --text-primary: #f0efe9;
      --text-secondary: #a0a09a;
      --text-tertiary: #6b6b67;
      --border: rgba(255,255,255,0.1);
      --border-hover: rgba(255,255,255,0.2);
      --blue-bg: #0c447c; --blue-text: #b5d4f4; --blue-border: #185fa5;
      --green-bg: #27500a; --green-text: #c0dd97; --green-border: #3b6d11;
      --red-bg: #791f1f; --red-text: #f7c1c1; --red-border: #a32d2d;
      --amber-bg: #633806; --amber-text: #fac775; --amber-border: #854f0b;
      --teal-bg: #085041; --teal-text: #9fe1cb; --teal-border: #0f6e56;
    }
  }

  html, body { height: 100%; background: var(--bg-tertiary); color: var(--text-primary); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; font-size: 14px; }
  .app { display: flex; height: 100vh; overflow: hidden; }

  /* SIDEBAR */
  .sidebar { width: 210px; flex-shrink: 0; background: var(--bg-primary); border-right: 0.5px solid var(--border); display: flex; flex-direction: column; padding: 0; overflow-y: auto; }
  .logo { padding: 16px; font-size: 15px; font-weight: 600; color: var(--text-primary); border-bottom: 0.5px solid var(--border); display: flex; align-items: center; gap: 8px; letter-spacing: -0.3px; }
  .logo i { font-size: 20px; color: var(--blue-mid); }
  .logo span { font-size: 11px; font-weight: 400; color: var(--text-tertiary); display: block; margin-top: 1px; }
  .nav-section { padding: 12px 8px 4px; font-size: 10px; font-weight: 600; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.8px; }
  .nav-item { display: flex; align-items: center; gap: 9px; padding: 8px 10px; margin: 0 6px; font-size: 13px; cursor: pointer; color: var(--text-secondary); border-radius: var(--radius-md); border: none; background: none; width: calc(100% - 12px); text-align: left; transition: background .12s, color .12s; }
  .nav-item:hover { background: var(--bg-secondary); color: var(--text-primary); }
  .nav-item.active { background: var(--bg-secondary); color: var(--text-primary); font-weight: 500; }
  .nav-item i { font-size: 17px; }
  .nav-badge { margin-left: auto; font-size: 10px; padding: 2px 6px; border-radius: 20px; background: var(--red-bg); color: var(--red-text); font-weight: 600; }
  .sidebar-footer { margin-top: auto; padding: 10px 6px 14px; border-top: 0.5px solid var(--border); }

  /* MAIN */
  .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; background: var(--bg-tertiary); }
  .topbar { padding: 12px 20px; background: var(--bg-primary); border-bottom: 0.5px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; }
  .topbar-info .title { font-size: 14px; font-weight: 600; color: var(--text-primary); }
  .topbar-info .sub { font-size: 11px; color: var(--text-secondary); margin-top: 1px; }
  .topbar-actions { display: flex; align-items: center; gap: 8px; }
  .status-dot { display: flex; align-items: center; gap: 5px; font-size: 11px; padding: 4px 10px; border-radius: 20px; font-weight: 500; cursor: default; }
  .status-dot::before { content:''; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .status-dot.connected { color: var(--green-text); background: var(--green-bg); }
  .status-dot.qr { color: var(--amber-text); background: var(--amber-bg); animation: pulse 2s infinite; }
  .status-dot.disconnected { color: var(--text-secondary); background: var(--bg-secondary); }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.6} }
  .content { flex: 1; overflow-y: auto; padding: 20px; }

  /* BUTTONS */
  .btn { background: var(--bg-primary); border: 0.5px solid var(--border-hover); border-radius: var(--radius-md); padding: 7px 13px; font-size: 12px; cursor: pointer; color: var(--text-primary); display: inline-flex; align-items: center; gap: 6px; transition: background .12s; font-family: inherit; text-decoration: none; }
  .btn:hover { background: var(--bg-secondary); }
  .btn i { font-size: 15px; }
  .btn-primary { background: var(--blue-bg); border-color: var(--blue-border); color: var(--blue-text); font-weight: 500; }
  .btn-primary:hover { filter: brightness(0.95); }
  .btn-sm { padding: 4px 9px; font-size: 11px; }
  .btn-sm i { font-size: 13px; }
  .btn:disabled { opacity: .5; cursor: not-allowed; }

  /* TABS */
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* KPI CARDS */
  .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
  .kpi-card { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 14px 16px; }
  .kpi-label { font-size: 11px; color: var(--text-secondary); margin-bottom: 6px; display: flex; align-items: center; gap: 5px; }
  .kpi-label i { font-size: 14px; }
  .kpi-value { font-size: 24px; font-weight: 600; color: var(--text-primary); letter-spacing: -0.5px; }
  .kpi-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 4px; }
  .kpi-bar { height: 3px; border-radius: 2px; background: var(--bg-secondary); overflow: hidden; margin-top: 8px; }
  .kpi-fill { height: 100%; border-radius: 2px; }
  .kpi-danger .kpi-value { color: var(--red-text); }
  .kpi-success .kpi-value { color: var(--green-text); }

  /* SECTION */
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; flex-wrap: wrap; gap: 8px; }
  .section-title { font-size: 13px; font-weight: 600; color: var(--text-primary); }
  .filters { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .filter-select { font-size: 12px; padding: 6px 10px; border-radius: var(--radius-md); border: 0.5px solid var(--border-hover); background: var(--bg-primary); color: var(--text-primary); cursor: pointer; font-family: inherit; }

  /* TABLE */
  .table-wrap { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
  table { width: 100%; border-collapse: collapse; font-size: 12px; table-layout: fixed; }
  th { padding: 9px 12px; text-align: left; font-size: 11px; font-weight: 600; color: var(--text-secondary); background: var(--bg-secondary); border-bottom: 0.5px solid var(--border); text-transform: uppercase; letter-spacing: 0.3px; }
  td { padding: 9px 12px; border-bottom: 0.5px solid var(--border); color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: var(--bg-secondary); }
  .empty-row td { text-align: center; color: var(--text-tertiary); padding: 32px; font-size: 12px; }

  /* BADGES */
  .badge { font-size: 10px; padding: 3px 8px; border-radius: 20px; font-weight: 600; display: inline-block; white-space: nowrap; }
  .b-agendada { background: var(--blue-bg); color: var(--blue-text); }
  .b-asistida { background: var(--green-bg); color: var(--green-text); }
  .b-cancelada { background: var(--red-bg); color: var(--red-text); }
  .b-pendiente { background: var(--amber-bg); color: var(--amber-text); }
  .b-pagado { background: var(--green-bg); color: var(--green-text); }
  .b-connected { background: var(--green-bg); color: var(--green-text); }
  .b-qr { background: var(--amber-bg); color: var(--amber-text); }
  .b-offline { background: var(--red-bg); color: var(--red-text); }

  /* ACTION BTNS */
  .abtn { background: none; border: 0.5px solid var(--border); border-radius: var(--radius-md); padding: 4px 8px; font-size: 11px; cursor: pointer; color: var(--text-secondary); display: inline-flex; align-items: center; gap: 3px; transition: all .12s; font-family: inherit; }
  .abtn:hover { background: var(--bg-secondary); color: var(--text-primary); border-color: var(--border-hover); }
  .abtn i { font-size: 13px; }
  .abtn-primary { border-color: var(--blue-border); color: var(--blue-text); }
  .abtn-primary:hover { background: var(--blue-bg); }
  .abtn-danger { border-color: var(--red-border); color: var(--red-text); }
  .abtn-danger:hover { background: var(--red-bg); }
  .actions-cell { display: flex; gap: 4px; align-items: center; flex-wrap: wrap; }

  /* MINI CHARTS */
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
  .chart-card { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 16px; }
  .chart-label { font-size: 11px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 12px; }
  .bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .bar-name { width: 90px; font-size: 11px; color: var(--text-secondary); text-align: right; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; }
  .bar-track { flex: 1; height: 8px; background: var(--bg-secondary); border-radius: 4px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 4px; background: var(--blue-mid); }
  .bar-val { width: 36px; font-size: 11px; font-weight: 600; color: var(--text-primary); text-align: right; }

  /* INVENTORY */
  .inv-bar { display: flex; align-items: center; gap: 6px; }
  .inv-track { flex: 1; height: 6px; background: var(--bg-secondary); border-radius: 3px; overflow: hidden; }
  .inv-fill { height: 100%; border-radius: 3px; }
  .stock-low { color: var(--red-text) !important; font-weight: 600; }
  .stock-ok { color: var(--green-text) !important; }
  .stock-warn { color: var(--amber-text) !important; font-weight: 600; }

  /* CALENDAR */
  .cal-wrap { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
  .cal-grid { display: grid; overflow-x: auto; }
  .cal-header { background: var(--bg-secondary); padding: 9px 6px; font-size: 11px; font-weight: 600; color: var(--text-secondary); text-align: center; border-bottom: 0.5px solid var(--border); border-right: 0.5px solid var(--border); }
  .cal-time-cell { background: var(--bg-secondary); padding: 6px 8px; font-size: 10px; color: var(--text-tertiary); border-bottom: 0.5px solid var(--border); border-right: 0.5px solid var(--border); text-align: right; white-space: nowrap; }
  .cal-cell { border-bottom: 0.5px solid var(--border); border-right: 0.5px solid var(--border); padding: 3px; min-height: 40px; }
  .cal-appt { font-size: 10px; padding: 3px 5px; border-radius: 4px; background: var(--blue-bg); color: var(--blue-text); margin-bottom: 2px; cursor: pointer; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 500; }
  .cal-appt.done { background: var(--green-bg); color: var(--green-text); }
  .cal-legend { display: flex; gap: 12px; padding: 10px 14px; border-top: 0.5px solid var(--border); font-size: 11px; color: var(--text-secondary); }
  .cal-legend span { display: flex; align-items: center; gap: 5px; }
  .leg-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }

  /* QR FORM */
  .qr-card { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 20px; max-width: 420px; flex: 1; min-width: 280px; }
  .form-group { display: flex; flex-direction: column; gap: 12px; }
  .form-input { padding: 8px 11px; border: 0.5px solid var(--border-hover); border-radius: var(--radius-md); background: var(--bg-primary); color: var(--text-primary); font-size: 13px; font-family: inherit; transition: border-color .12s; width: 100%; }
  .form-input:focus { outline: none; border-color: var(--blue-mid); }
  .form-label { font-size: 11px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 5px; display: block; }

  /* QR Code box */
  .qr-box { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 24px; text-align: center; min-width: 200px; }
  #qr-display { width: 180px; height: 180px; background: white; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; overflow: hidden; }
  #qr-display img { width: 100%; height: 100%; object-fit: contain; }

  /* WHATSAPP CHAT PANEL */
  .chat-panel { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; height: calc(100vh - 320px); min-height: 400px; display: flex; flex-direction: column; }
  .chat-sidebar { width: 240px; flex-shrink: 0; border-right: 0.5px solid var(--border); overflow-y: auto; }
  .chat-messages-area { flex: 1; overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 10px; background: var(--bg-tertiary); }
  .conv-item { padding: 10px 12px; cursor: pointer; border-bottom: 0.5px solid var(--border); transition: background .1s; }
  .conv-item:hover, .conv-item.active { background: var(--bg-secondary); }
  .conv-name { font-size: 12px; font-weight: 600; margin-bottom: 2px; }
  .conv-preview { font-size: 11px; color: var(--text-secondary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .conv-time { font-size: 10px; color: var(--text-tertiary); float: right; }
  .msg-bubble { max-width: 72%; padding: 8px 12px; border-radius: 10px; font-size: 12px; line-height: 1.5; word-wrap: break-word; }
  .msg-bubble.user { background: var(--bg-primary); border: 0.5px solid var(--border); align-self: flex-start; border-bottom-left-radius: 3px; }
  .msg-bubble.assistant { background: var(--blue-mid); color: white; align-self: flex-end; border-bottom-right-radius: 3px; }
  .msg-role { font-size: 10px; color: var(--text-tertiary); margin-top: 3px; text-align: right; }
  .chat-header { padding: 10px 14px; border-bottom: 0.5px solid var(--border); font-size: 12px; font-weight: 600; background: var(--bg-primary); }

  /* CLIENTS GRID */
  .clients-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; }
  .client-card { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; }
  .client-card-header { padding: 14px 16px 10px; border-bottom: 0.5px solid var(--border); }
  .client-name { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .client-meta { font-size: 11px; color: var(--text-secondary); display: flex; gap: 10px; flex-wrap: wrap; }
  .client-stats { display: grid; grid-template-columns: repeat(3, 1fr); border-bottom: 0.5px solid var(--border); }
  .client-stat { padding: 10px; text-align: center; border-right: 0.5px solid var(--border); }
  .client-stat:last-child { border-right: none; }
  .client-stat-val { font-size: 16px; font-weight: 700; }
  .client-stat-lbl { font-size: 10px; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.3px; }
  .client-actions { padding: 10px 14px; display: flex; gap: 6px; }
  .client-actions .btn { flex: 1; justify-content: center; font-size: 11px; }

  /* MODAL */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; align-items: center; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--bg-primary); border: 0.5px solid var(--border); border-radius: var(--radius-xl); padding: 22px; width: 420px; max-width: 94vw; box-shadow: 0 20px 60px rgba(0,0,0,.2); }
  .modal-title { font-size: 14px; font-weight: 600; margin-bottom: 14px; display: flex; justify-content: space-between; align-items: center; color: var(--text-primary); }
  .modal textarea { width: 100%; min-height: 90px; font-size: 13px; border: 0.5px solid var(--border-hover); border-radius: var(--radius-md); padding: 10px; background: var(--bg-primary); color: var(--text-primary); font-family: inherit; resize: vertical; }
  .modal textarea:focus { outline: none; border-color: var(--blue-mid); }
  .modal-footer { display: flex; justify-content: flex-end; gap: 8px; margin-top: 14px; }

  /* NEW APPOINTMENT MODAL */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .form-field { display: flex; flex-direction: column; gap: 5px; }
  .form-field.full { grid-column: 1 / -1; }

  /* TOAST */
  .toast { position: fixed; bottom: 24px; right: 24px; background: var(--text-primary); color: var(--bg-primary); padding: 10px 16px; border-radius: var(--radius-md); font-size: 13px; z-index: 300; opacity: 0; transform: translateY(8px); transition: all .25s; pointer-events: none; display: flex; align-items: center; gap: 6px; max-width: 320px; }
  .toast.show { opacity: 1; transform: translateY(0); }
  .toast i { font-size: 16px; color: #7fe4b3; flex-shrink: 0; }
  .toast.error i { color: #f7c1c1; }

  /* SPINNER */
  .spinner { width: 20px; height: 20px; border: 2px solid var(--border); border-top-color: var(--blue-mid); border-radius: 50%; animation: spin .7s linear infinite; display: inline-block; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border-hover); border-radius: 3px; }

  @media (max-width: 900px) {
    .kpi-grid { grid-template-columns: repeat(2,1fr); }
    .two-col { grid-template-columns: 1fr; }
    .sidebar { width: 52px; }
    .sidebar .logo div, .sidebar .nav-section, .nav-item span { display: none; }
    .nav-item { justify-content: center; padding: 10px; }
    .sidebar-footer { display: none; }
  }
  @media (max-width: 600px) {
    .sidebar { display: none; }
    .kpi-grid { grid-template-columns: 1fr 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }

  /* Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ PANTALLA DE LOGIN — SOLO QR DE REGISTRO Ã¢â€â‚¬Ã¢â€â‚¬Ã¢â€â‚¬ */
  .login-container {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1000;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #0a0f1e;
  }
  .login-orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    animation: orbFloat 14s ease-in-out infinite;
  }
  .login-orb-1 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(55,138,221,0.28), transparent 70%);
    top: -200px; left: -120px;
  }
  .login-orb-2 {
    width: 450px; height: 450px;
    background: radial-gradient(circle, rgba(108,92,231,0.22), transparent 70%);
    bottom: -130px; right: -80px;
    animation-delay: -7s;
  }
  .login-orb-3 {
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(0,210,130,0.12), transparent 70%);
    top: 55%; left: 55%;
    animation-delay: -3.5s;
  }
  @keyframes orbFloat {
    0%, 100% { transform: translate(0,0); }
    33% { transform: translate(25px,-35px); }
    66% { transform: translate(-18px,18px); }
  }
  .login-wrapper {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: 20px;
  }
  .login-card {
    background: rgba(255,255,255,0.04);
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: 24px;
    padding: 36px 32px 32px;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 28px 80px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.08);
    animation: loginCardIn 0.45s cubic-bezier(0.34,1.56,0.64,1) forwards;
  }
  @keyframes loginCardIn {
    from { opacity:0; transform:translateY(18px) scale(0.97); }
    to   { opacity:1; transform:translateY(0) scale(1); }
  }
  .login-logo-wrap { text-align: center; margin-bottom: 24px; }
  .login-logo-icon {
    width: 60px; height: 60px;
    background: linear-gradient(135deg, #378add 0%, #1a5fa5 100%);
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
    box-shadow: 0 8px 24px rgba(55,138,221,0.45);
    animation: float 4s ease-in-out infinite;
  }
  .login-logo-icon i { font-size: 30px; color: #fff; }
  .login-title {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
  }
  .login-subtitle {
    font-size: 12px;
    color: rgba(255,255,255,0.45);
    line-height: 1.45;
  }
  /* Config warning */
  .login-config-warn {
    display: none;
    background: rgba(245,158,11,0.13);
    border: 1px solid rgba(245,158,11,0.35);
    border-radius: 10px;
    padding: 11px 13px;
    font-size: 11.5px;
    color: #fcd34d;
    line-height: 1.55;
    margin-bottom: 16px;
    text-align: left;
  }
  .login-config-warn code {
    background: rgba(255,255,255,0.1);
    padding: 1px 5px;
    border-radius: 4px;
    font-size: 10.5px;
  }
  /* Tabs */
  .login-tabs {
    display: flex;
    gap: 3px;
    background: rgba(255,255,255,0.05);
    border-radius: 11px;
    padding: 4px;
    margin-bottom: 22px;
  }
  .login-tab {
    flex: 1;
    padding: 8px 4px;
    background: none;
    border: none;
    border-radius: 8px;
    font-size: 11.5px;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    white-space: nowrap;
  }
  .login-tab.active {
    background: rgba(55,138,221,0.28);
    color: #93c5fd;
    border: 1px solid rgba(55,138,221,0.35);
  }
  .login-tab:hover:not(.active) {
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.06);
  }
  /* Panels */
  .login-panel { display: none; }
  .login-panel.active { display: block; }
  /* Fields */
  .login-field { margin-bottom: 14px; }
  .login-label {
    display: block;
    font-size: 10.5px;
    font-weight: 600;
    color: rgba(255,255,255,0.45);
    text-transform: uppercase;
    letter-spacing: 0.55px;
    margin-bottom: 6px;
  }
  .login-input {
    width: 100%;
    padding: 11px 13px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.11);
    border-radius: 10px;
    color: #fff;
    font-size: 14px;
    font-family: inherit;
    transition: all 0.15s;
  }
  .login-input::placeholder { color: rgba(255,255,255,0.28); }
  .login-input:focus {
    outline: none;
    border-color: rgba(55,138,221,0.65);
    background: rgba(55,138,221,0.1);
  }
  /* Buttons */
  .login-btn {
    width: 100%;
    padding: 12px;
    background: linear-gradient(135deg, #378add 0%, #2563eb 100%);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 4px;
    box-shadow: 0 4px 16px rgba(55,138,221,0.4);
  }
  .login-btn:hover { background: linear-gradient(135deg,#2a7bcd,#1d4ed8); transform: translateY(-1px); box-shadow: 0 6px 22px rgba(55,138,221,0.55); }
  .login-btn:active { transform: scale(0.98); }
  .login-btn:disabled { opacity: 0.45; cursor: not-allowed; transform: none !important; box-shadow: none; }
  .login-btn-ghost {
    background: rgba(255,255,255,0.09);
    box-shadow: none;
    border: 1px solid rgba(255,255,255,0.12);
  }
  .login-btn-ghost:hover { background: rgba(255,255,255,0.14); transform: translateY(-1px); box-shadow: none; }
  /* Error & success */
  .login-error {
    background: rgba(239,68,68,0.14);
    color: #fca5a5;
    border: 1px solid rgba(239,68,68,0.3);
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 12px;
    display: none;
    line-height: 1.4;
    margin-bottom: 14px;
  }
  .login-success {
    background: rgba(0,210,130,0.12);
    color: #6ee7b7;
    border: 1px solid rgba(0,210,130,0.25);
    border-radius: 10px;
    padding: 12px;
    font-size: 12.5px;
    display: none;
    line-height: 1.45;
    text-align: center;
    margin-bottom: 14px;
  }
  /* QR Panel */
  .qr-access-area { text-align: center; padding: 4px 0 0; }
  .qr-canvas-wrap {
    background: #fff;
    display: inline-block;
    padding: 12px;
    border-radius: 14px;
    margin-bottom: 14px;
    box-shadow: 0 4px 18px rgba(0,0,0,0.35);
  }
  .qr-canvas-wrap canvas { display: block; border-radius: 4px; }
  .qr-info-text {
    font-size: 12px;
    color: rgba(255,255,255,0.5);
    line-height: 1.5;
    margin-bottom: 14px;
  }
  .login-divider {
    text-align: center;
    font-size: 11px;
    color: rgba(255,255,255,0.25);
    margin: 14px 0 0;
  }
  /* Spinner */
  .login-spinner {
    width: 15px; height: 15px;
    border: 2px solid rgba(255,255,255,0.25);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
    display: inline-block;
    vertical-align: middle;
  }

  /* PIN MODAL */
  .pin-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.7); backdrop-filter:blur(8px); z-index:500; align-items:center; justify-content:center; }
  .pin-modal-overlay.open { display:flex; }
  .pin-modal-card { background:var(--bg-primary); border:0.5px solid var(--border); border-radius:20px; padding:32px 28px; width:340px; max-width:94vw; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.4); animation:loginCardIn 0.3s ease forwards; }
  .pin-display { font-size:28px; font-weight:700; letter-spacing:12px; color:var(--text-primary); background:var(--bg-secondary); border-radius:10px; padding:14px; margin:16px 0; min-height:58px; border:0.5px solid var(--border); }
  .pin-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:16px; }
  .pin-btn { padding:16px; font-size:18px; font-weight:600; background:var(--bg-secondary); border:0.5px solid var(--border); border-radius:10px; cursor:pointer; color:var(--text-primary); transition:all .12s; font-family:inherit; }
  .pin-btn:hover { background:var(--bg-tertiary); transform:scale(0.97); }
  .pin-btn:active { transform:scale(0.93); }
  .pin-error { color:var(--red-text); font-size:12px; margin-top:8px; display:none; }
  @keyframes shake { 0%,100%{transform:translateX(0)} 20%,60%{transform:translateX(-8px)} 40%,80%{transform:translateX(8px)} }

  /* ═══ PACIENTES — EXPEDIENTE CLÍNICO ═══ */

  .patients-split {
    display: flex;
    gap: 0;
    height: calc(100vh - 110px);
    min-height: 500px;
    overflow: hidden;
    border: 0.5px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-primary);
  }

  /* Left pane: patient list */
  .patients-list-pane {
    width: 260px;
    min-width: 220px;
    border-right: 0.5px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .patients-search {
    padding: 12px;
    border-bottom: 0.5px solid var(--border);
  }

  .patients-search input {
    width: 100%;
    background: var(--bg-secondary);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 7px 10px;
    font-size: 12px;
    color: var(--text-primary);
    outline: none;
    box-sizing: border-box;
  }

  .patients-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 6px;
  }

  .patient-list-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background .15s;
    border: 0.5px solid transparent;
  }

  .patient-list-item:hover {
    background: var(--bg-secondary);
  }

  .patient-list-item.active {
    background: var(--bg-secondary);
    border-color: var(--border);
  }

  .patient-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--blue-mid) 0%, #7c3aed 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .patient-list-info {
    flex: 1;
    min-width: 0;
  }

  .patient-list-name {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .patient-list-phone {
    font-size: 10.5px;
    color: var(--text-tertiary);
    margin-top: 1px;
  }

  /* Right pane: patient record */
  .patients-record-pane {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-width: 0;
  }

  .patient-record-header {
    padding: 16px 20px 12px;
    border-bottom: 0.5px solid var(--border);
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--bg-primary);
  }

  .patient-record-avatar {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--blue-mid) 0%, #7c3aed 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .patient-record-title {
    flex: 1;
    min-width: 0;
  }

  .patient-record-name {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary);
  }

  .patient-record-sub {
    font-size: 11px;
    color: var(--text-tertiary);
    margin-top: 2px;
  }

  /* Sub-tabs inside record pane */
  .patient-subtabs {
    display: flex;
    gap: 0;
    border-bottom: 0.5px solid var(--border);
    padding: 0 16px;
    background: var(--bg-primary);
    overflow-x: auto;
  }

  .patient-subtab {
    padding: 9px 14px;
    font-size: 12px;
    color: var(--text-secondary);
    cursor: pointer;
    border: none;
    background: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color .15s, border-color .15s;
    font-weight: 500;
  }

  .patient-subtab:hover { color: var(--text-primary); }
  .patient-subtab.active { color: var(--blue-mid); border-bottom-color: var(--blue-mid); }

  .patient-subtab-content {
    display: none;
    flex: 1;
    overflow-y: auto;
    padding: 16px 20px;
  }

  .patient-subtab-content.active { display: block; }

  /* Info grid inside ficha */
  .patient-info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 16px;
  }

  .patient-info-field label {
    font-size: 10px;
    color: var(--text-tertiary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    display: block;
    margin-bottom: 3px;
  }

  .patient-info-field span {
    font-size: 13px;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* Clinical items (diagnostics, prescriptions, labs) */
  .clinical-item {
    background: var(--bg-secondary);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 10px 13px;
    margin-bottom: 8px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .clinical-item-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }

  .clinical-item-text { flex: 1; min-width: 0; }
  .clinical-item-label { font-size: 12.5px; font-weight: 600; color: var(--text-primary); }
  .clinical-item-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 2px; }

  /* Timeline */
  .timeline-feed {
    position: relative;
    padding-left: 28px;
  }

  .timeline-feed::before {
    content: '';
    position: absolute;
    left: 10px;
    top: 4px;
    bottom: 4px;
    width: 1.5px;
    background: var(--border);
  }

  .timeline-event {
    position: relative;
    margin-bottom: 14px;
  }

  .timeline-dot {
    position: absolute;
    left: -23px;
    top: 5px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid var(--bg-primary);
    flex-shrink: 0;
  }

  .timeline-card {
    background: var(--bg-secondary);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-md);
    padding: 9px 13px;
  }

  .timeline-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3px;
  }

  .timeline-card-title { font-size: 12.5px; font-weight: 600; color: var(--text-primary); }
  .timeline-card-date { font-size: 10.5px; color: var(--text-tertiary); }
  .timeline-card-body { font-size: 11.5px; color: var(--text-secondary); line-height: 1.4; }

  /* Chat transcript */
  .chat-transcript { display: flex; flex-direction: column; gap: 8px; }

  .chat-bubble {
    max-width: 72%;
    padding: 8px 12px;
    border-radius: 12px;
    font-size: 12.5px;
    line-height: 1.45;
    word-break: break-word;
  }

  .chat-bubble.user {
    background: var(--bg-secondary);
    border: 0.5px solid var(--border);
    color: var(--text-primary);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }

  .chat-bubble.assistant {
    background: linear-gradient(135deg, rgba(59,130,246,.15), rgba(124,58,237,.15));
    border: 0.5px solid rgba(59,130,246,.3);
    color: var(--text-primary);
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }

  .chat-bubble-meta {
    font-size: 9.5px;
    color: var(--text-tertiary);
    margin-top: 3px;
  }

  .patients-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--text-tertiary);
    font-size: 13px;
    gap: 10px;
    padding: 40px;
  }

  .patients-empty i { font-size: 40px; opacity: 0.3; }

  @media (max-width: 768px) {
    .patients-split { flex-direction: column; height: auto; }
    .patients-list-pane { width: 100%; border-right: none; border-bottom: 0.5px solid var(--border); max-height: 220px; }
    .patient-info-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â PANTALLA DE LOGIN — QR REGISTRO Ã¢â€¢ÂÃ¢â€¢ÂÃ¢â€¢Â -->
<div class="login-container" id="login-container">
  <div class="login-orb login-orb-1"></div>
  <div class="login-orb login-orb-2"></div>
  <div class="login-orb login-orb-3"></div>

  <div class="login-wrapper">
    <div class="login-card">

      <!-- Logo (doble clic = panel admin) -->
      <div class="login-logo-wrap">
        <div class="login-logo-icon" id="login-logo-icon" ondblclick="revealAdminPanel()" title="">
          <i class="ti ti-tooth"></i>
        </div>
        <h1 class="login-title">DentaFlow</h1>
        <p class="login-subtitle" id="login-biz-subtitle">Escanea el código para registrar tu llegada</p>
      </div>

      <!-- QR de registro de pacientes (vista principal) -->
      <div class="login-qr-section" id="login-qr-section">
        <div class="login-qr-title">Registro de Pacientes</div>
        <div class="login-qr-hint">Apunta tu cámara al código QR para registrar tu visita</div>
        <div class="login-qr-box" id="login-reg-qr-box">
          <span class="login-spinner" id="login-reg-spinner" style="display:inline-block"></span>
          <img id="login-reg-qr-img" style="display:none" alt="QR Registro">
        </div>
        <div class="login-qr-url" id="login-reg-qr-url"></div>
      </div>

      <!-- Panel admin oculto (doble clic en logo) -->
      <div class="admin-login-panel" id="admin-login-panel">
        <div class="admin-panel-label">Acceso Administrador</div>
        <div class="login-error" id="login-error-box"></div>
        <div class="login-field">
          <label class="login-label" for="login-username">Usuario</label>
          <input type="text" class="login-input" id="login-username" placeholder="admin" autocomplete="username">
        </div>
        <div class="login-field">
          <label class="login-label" for="login-password">Contraseña</label>
          <input type="password" class="login-input" id="login-password" placeholder="Ã¢â‚¬Â¢Ã¢â‚¬Â¢Ã¢â‚¬Â¢Ã¢â‚¬Â¢Ã¢â‚¬Â¢Ã¢â‚¬Â¢Ã¢â‚¬Â¢Ã¢â‚¬Â¢" autocomplete="current-password"
            onkeydown="if(event.key==='Enter') handleLogin()">
        </div>
        <button class="login-btn" id="btn-login" onclick="handleLogin()">
          <i class="ti ti-login"></i>
          <span id="btn-login-text">Ingresar al Panel</span>
        </button>
      </div>

    </div><!-- /.login-card -->
  </div><!-- /.login-wrapper -->
</div>

<div class="app" id="main-app" style="display:none">
  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="logo">
      <i class="ti ti-tooth"></i>
      <div>DentaFlow<span id="biz-name-logo">Gestión Clínica</span></div>
    </div>
    <div class="nav-section">Principal</div>
    <button class="nav-item active" id="nav-dashboard" onclick="showTab('dashboard',this)"><i class="ti ti-layout-dashboard"></i><span>Dashboard</span></button>
    <button class="nav-item" id="nav-whatsapp" onclick="showTab('whatsapp',this)"><i class="ti ti-brand-whatsapp"></i><span>WhatsApp</span></button>
    <button class="nav-item" id="nav-citas" onclick="showTab('citas',this)"><i class="ti ti-calendar-event"></i><span>Citas</span></button>
    <div class="nav-section">Clínica</div>
    <button class="nav-item" id="nav-inventario" onclick="showTab('inventario',this)"><i class="ti ti-package"></i><span>Inventario</span> <span class="nav-badge" id="inv-alert-badge" style="display:none">!</span></button>
    <button class="nav-item" id="nav-pagos" onclick="showTab('pagos',this)"><i class="ti ti-receipt"></i><span>Pagos</span></button>
    <button class="nav-item" id="nav-agenda" onclick="showTab('agenda',this)"><i class="ti ti-calendar-week"></i><span>Agenda</span></button>
    <button class="nav-item" id="nav-pacientes" onclick="showTab('pacientes',this)"><i class="ti ti-user-heart"></i><span>Pacientes</span></button>
    <div class="nav-section">Acceso</div>
    <button class="nav-item" id="nav-qr" onclick="showTab('qr',this)"><i class="ti ti-qrcode"></i><span>Registro QR</span></button>
    <button class="nav-item" id="nav-clientes" onclick="requestMultiBotAccess(this)"><i class="ti ti-users"></i><span>Multi-Bots</span><i class="ti ti-lock" style="margin-left:auto;font-size:13px;opacity:0.5" id="multibots-lock-icon"></i></button>
    <div class="sidebar-footer">
      <button class="nav-item" onclick="openMobileLoginModal()" style="color:var(--accent-blue)"><i class="ti ti-device-mobile"></i><span>Acceso Móvil</span></button>
      <button class="nav-item" id="nav-config" onclick="showTab('config',this)"><i class="ti ti-settings"></i><span>Configuración</span></button>
      <button class="nav-item" onclick="handleLogout()" style="color:var(--red-text)"><i class="ti ti-logout"></i><span>Cerrar sesión</span></button>
    </div>
  </nav>

  <!-- MAIN -->
  <div class="main">
    <div class="topbar">
      <div class="topbar-info">
        <div class="title" id="topbar-biz">Cargando...</div>
        <div class="sub" id="topbar-sub">Bot de WhatsApp con IA</div>
      </div>
      <div class="topbar-actions">
        <span class="status-dot disconnected" id="wa-status-badge">Conectando...</span>
        <button class="btn btn-primary" onclick="openNewAppointment()"><i class="ti ti-plus"></i>Nueva cita</button>
      </div>
    </div>

    <div class="content">

      <!-- ===== DASHBOARD ===== -->
      <div id="tab-dashboard" class="tab-panel active">
        <div class="kpi-grid">
          <div class="kpi-card">
            <div class="kpi-label"><i class="ti ti-messages"></i>Mensajes totales</div>
            <div class="kpi-value" id="kpi-messages">—</div>
            <div class="kpi-sub" id="kpi-conversations">— conversaciones</div>
            <div class="kpi-bar"><div class="kpi-fill" id="kpi-msg-bar" style="width:0%;background:var(--blue-mid)"></div></div>
          </div>
          <div class="kpi-card kpi-success">
            <div class="kpi-label"><i class="ti ti-calendar-check"></i>Citas agendadas</div>
            <div class="kpi-value" id="kpi-appointments">—</div>
            <div class="kpi-sub" id="kpi-apt-sub">registradas por el bot</div>
            <div class="kpi-bar"><div class="kpi-fill" id="kpi-apt-bar" style="width:0%;background:#639922"></div></div>
          </div>
          <div class="kpi-card kpi-danger">
            <div class="kpi-label"><i class="ti ti-alert-triangle"></i>Insumos en alerta</div>
            <div class="kpi-value" id="kpi-inv-alert">—</div>
            <div class="kpi-sub">bajo stock mínimo</div>
            <div class="kpi-bar"><div class="kpi-fill" id="kpi-inv-bar" style="width:0%;background:#E24B4A"></div></div>
          </div>
          <div class="kpi-card">
            <div class="kpi-label"><i class="ti ti-clock"></i>Tiempo activo</div>
            <div class="kpi-value" id="kpi-uptime">—</div>
            <div class="kpi-sub">servidor en línea</div>
            <div class="kpi-bar"><div class="kpi-fill" style="width:100%;background:var(--blue-mid)"></div></div>
          </div>
        </div>

        <div class="two-col">
          <div class="chart-card">
            <div class="chart-label">Citas por servicio</div>
            <div id="services-chart">
              <div style="color:var(--text-tertiary);font-size:12px;padding:20px 0">Cargando datos...</div>
            </div>
          </div>
          <div class="chart-card">
            <div class="chart-label">Estado de citas</div>
            <div id="status-summary" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px"></div>
            <div id="apt-chart">
              <div style="color:var(--text-tertiary);font-size:12px;padding:20px 0">Cargando datos...</div>
            </div>
          </div>
        </div>

        <div class="section-header">
          <span class="section-title">Citas recientes</span>
          <button class="btn btn-sm" onclick="showTab('citas',document.getElementById('nav-citas'))"><i class="ti ti-arrow-right"></i>Ver todas</button>
        </div>
        <div class="table-wrap">
          <table>
            <colgroup><col style="width:140px"><col style="width:130px"><col style="width:100px"><col style="width:80px"><col></colgroup>
            <thead><tr><th>Paciente</th><th>Tratamiento</th><th>Fecha / Hora</th><th>Estado</th><th>Acciones</th></tr></thead>
            <tbody id="recent-apts-body">
              <tr class="empty-row"><td colspan="5"><span class="spinner"></span></td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ===== WHATSAPP ===== -->
      <div id="tab-whatsapp" class="tab-panel">
        <div class="section-header">
          <span class="section-title">Conversaciones WhatsApp</span>
          <span class="status-dot disconnected" id="wa-status-badge-2">Conectando...</span>
        </div>
        <div id="qr-overlay-wa" style="display:none; text-align:center; padding: 40px 20px; background:var(--bg-primary); border:0.5px solid var(--border); border-radius:var(--radius-lg);">
          <div id="qr-loading-wa" style="color:var(--text-secondary); font-size:13px;">
            <div class="spinner" style="margin:0 auto 12px"></div>
            Generando código QR...
          </div>
          <div id="qr-img-wa" style="display:none">
            <img id="qr-image-wa" src="" alt="QR WhatsApp" style="width:220px;height:220px;background:white;padding:8px;border-radius:8px;display:block;margin:0 auto 10px">
            <p style="font-size:12px;color:var(--text-secondary)">Escanea con WhatsApp Ã¢â€ â€™ Dispositivos vinculados</p>
          </div>
        </div>
        <div id="wa-chat-panel" class="chat-panel" style="display:none">
          <div style="display:flex;height:100%">
            <div class="chat-sidebar">
              <div class="chat-header">Chats activos</div>
              <div id="conv-list"></div>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;overflow:hidden">
              <div class="chat-header" id="chat-title-wa">Selecciona una conversación</div>
              <div class="chat-messages-area" id="chat-msgs-wa">
                <div style="text-align:center;color:var(--text-tertiary);font-size:12px;margin:auto">Selecciona un chat para ver los mensajes</div>
              </div>
              <!-- INPUT DE MENSAJE MANUAL -->
              <div class="chat-input-area" id="chat-input-area-wa" style="display:none; padding:12px; border-top:0.5px solid var(--border); display:flex; gap:8px; background:var(--bg-secondary)">
                <input type="text" class="form-input" id="chat-input-msg-wa" placeholder="Escribe un mensaje..." style="flex:1" onkeydown="if(event.key==='Enter') sendManualMessage()">
                <button class="btn btn-primary" onclick="sendManualMessage()"><i class="ti ti-send"></i>Enviar</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ===== CITAS ===== -->
      <div id="tab-citas" class="tab-panel">
        <div class="section-header">
          <span class="section-title">Gestión de citas</span>
          <div class="filters">
            <select class="filter-select" id="filtro-estado" onchange="filtrarCitas()">
              <option value="">Todos los estados</option>
              <option value="confirmada">Confirmada</option>
              <option value="asistida">Asistida</option>
              <option value="cancelada">Cancelada</option>
            </select>
            <button class="btn btn-sm" id="btn-recordar-todos" onclick="sendAllReminders()" style="background:var(--amber-bg);color:var(--amber-text);border:1px solid var(--amber-border);font-weight:500;" title="Enviar recordatorio a todas las citas filtradas"><i class="ti ti-bell"></i>Recordar a todos</button>
            <button class="btn btn-sm" onclick="exportCitasToExcel()" style="background:var(--green-bg);color:var(--green-text);border:1px solid var(--green-border);font-weight:500;" title="Exportar citas a Excel"><i class="ti ti-file-spreadsheet"></i>Exportar Excel</button>
            <button class="btn btn-primary btn-sm" onclick="openNewAppointment()"><i class="ti ti-plus"></i>Nueva cita</button>
          </div>
        </div>
        <div class="table-wrap">
          <table>
            <colgroup><col style="width:130px"><col style="width:110px"><col style="width:130px"><col style="width:100px"><col style="width:80px"><col></colgroup>
            <thead><tr><th>Paciente</th><th>Teléfono</th><th>Tratamiento</th><th>Fecha / Hora</th><th>Estado</th><th>Acciones</th></tr></thead>
            <tbody id="citas-body">
              <tr class="empty-row"><td colspan="6"><span class="spinner"></span></td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ===== INVENTARIO ===== -->
      <div id="tab-inventario" class="tab-panel">
        <div class="section-header">
          <span class="section-title">Inventario de insumos</span>
          <div class="filters">
            <button class="btn btn-sm" onclick="exportInventarioToExcel()" style="background:var(--green-bg);color:var(--green-text);border:1px solid var(--green-border);font-weight:500;" title="Exportar inventario a Excel"><i class="ti ti-file-spreadsheet"></i>Exportar Excel</button>
            <button class="btn btn-primary btn-sm" onclick="openNewInsumo()"><i class="ti ti-plus"></i>Agregar insumo</button>
          </div>
        </div>
        <div class="kpi-grid" style="grid-template-columns:repeat(3,1fr);margin-bottom:16px">
          <div class="kpi-card"><div class="kpi-label">Total insumos</div><div class="kpi-value" id="inv-total" style="font-size:20px">—</div></div>
          <div class="kpi-card kpi-danger"><div class="kpi-label"><i class="ti ti-alert-triangle"></i>En alerta</div><div class="kpi-value" id="inv-alerta" style="font-size:20px">—</div></div>
          <div class="kpi-card kpi-success"><div class="kpi-label">Stock normal</div><div class="kpi-value" id="inv-normal" style="font-size:20px">—</div></div>
        </div>
        <div class="table-wrap">
          <table>
            <colgroup><col style="width:160px"><col style="width:100px"><col style="width:80px"><col style="width:80px"><col style="width:70px"><col><col style="width:110px"></colgroup>
            <thead><tr><th>Insumo</th><th>Categoría</th><th>Stock actual</th><th>Stock mín.</th><th>Unidad</th><th>Nivel</th><th>Acciones</th></tr></thead>
            <tbody id="inv-body">
              <tr class="empty-row"><td colspan="7"><span class="spinner"></span></td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ===== PAGOS ===== -->
      <div id="tab-pagos" class="tab-panel">
        <div class="section-header">
          <span class="section-title">Pagos y facturación</span>
          <div class="filters">
            <input type="text" class="filter-select" placeholder="Buscar paciente..." id="pago-search" oninput="filtrarPagos()">
            <button class="btn btn-sm" onclick="exportPagosToExcel()" style="background:var(--green-bg);color:var(--green-text);border:1px solid var(--green-border);font-weight:500;" title="Exportar pagos a Excel"><i class="ti ti-file-spreadsheet"></i>Exportar Excel</button>
            <button class="btn btn-primary btn-sm" onclick="openNewPago()"><i class="ti ti-plus"></i>Registrar pago</button>
          </div>
        </div>
        <div class="kpi-grid" style="margin-bottom:16px">
          <div class="kpi-card"><div class="kpi-label"><i class="ti ti-cash"></i>Total cobrado</div><div class="kpi-value" id="pay-total" style="font-size:18px">—</div><div class="kpi-sub">este mes</div></div>
          <div class="kpi-card kpi-danger"><div class="kpi-label"><i class="ti ti-clock"></i>Pendiente</div><div class="kpi-value" id="pay-pending" style="font-size:18px">—</div><div class="kpi-sub" id="pay-pending-count"></div></div>
          <div class="kpi-card"><div class="kpi-label"><i class="ti ti-wallet"></i>Pagos registrados</div><div class="kpi-value" id="pay-count" style="font-size:18px">—</div><div class="kpi-sub">en total</div></div>
          <div class="kpi-card kpi-success"><div class="kpi-label"><i class="ti ti-circle-check"></i>Completados</div><div class="kpi-value" id="pay-done" style="font-size:18px">—</div><div class="kpi-sub">pagados</div></div>
        </div>
        <div class="table-wrap">
          <table>
            <colgroup><col style="width:50px"><col style="width:120px"><col><col style="width:90px"><col style="width:100px"><col style="width:70px"><col style="width:70px"><col style="width:100px"></colgroup>
            <thead><tr><th>#</th><th>Paciente</th><th>Servicio</th><th>Monto (RD$)</th><th>Forma de pago</th><th>Fecha</th><th>Estado</th><th>Acciones</th></tr></thead>
            <tbody id="pagos-body">
              <tr class="empty-row"><td colspan="8"><span class="spinner"></span></td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ===== AGENDA ===== -->
      <div id="tab-agenda" class="tab-panel">
        <div class="section-header">
          <span class="section-title" id="agenda-title">Agenda semanal</span>
          <div class="filters">
            <button class="btn btn-sm" onclick="changeWeek(-1)"><i class="ti ti-chevron-left"></i>Anterior</button>
            <button class="btn btn-sm" onclick="changeWeek(1)">Siguiente<i class="ti ti-chevron-right"></i></button>
          </div>
        </div>
        <div class="cal-wrap">
          <div class="cal-grid" id="calendar-grid"></div>
          <div class="cal-legend">
            <span><span class="leg-dot" style="background:var(--blue-bg);border:1px solid var(--blue-border)"></span>Confirmada</span>
            <span><span class="leg-dot" style="background:var(--green-bg);border:1px solid var(--green-border)"></span>Asistida</span>
            <span><span class="leg-dot" style="background:var(--red-bg);border:1px solid var(--red-border)"></span>Cancelada</span>
          </div>
        </div>
      </div>

      <!-- ===== QR REGISTRO ===== -->
      <div id="tab-qr" class="tab-panel">
        <div class="section-header">
          <span class="section-title">Ã°Å¸â€œÂ± Registro de Pacientes — QR</span>
          <button class="btn btn-sm" onclick="loadRegistroQR()"><i class="ti ti-refresh"></i>Actualizar QR</button>
        </div>
        <div style="display:flex;gap:20px;flex-wrap:wrap;align-items:flex-start">
          <!-- QR Box (server-generated with LAN IP) -->
          <div class="qr-box" style="min-width:220px">
            <div id="qr-display" style="min-height:220px;display:flex;align-items:center;justify-content:center">
              <span class="spinner"></span>
            </div>
            <div style="font-size:12px;color:var(--text-secondary);font-weight:600;margin-top:8px">Ã°Å¸â€œÂ± Escanea para registrarte</div>
            <div style="font-size:10px;color:var(--text-tertiary);margin-top:3px;word-break:break-all" id="qr-url-label">Cargando URL...</div>
            <button class="btn btn-sm" style="margin-top:12px;width:100%;justify-content:center" onclick="window.open('/registro.html','_blank')"><i class="ti ti-external-link"></i>Abrir página</button>
          </div>

          <div class="qr-card">
            <div class="section-title" style="margin-bottom:14px">Registro rápido manual</div>
            <div class="form-group">
              <div>
                <label class="form-label">Nombre completo</label>
                <input type="text" class="form-input" id="reg-nombre" placeholder="Ej: Juan Pérez">
              </div>
              <div>
                <label class="form-label">Teléfono WhatsApp</label>
                <input type="tel" class="form-input" id="reg-telefono" placeholder="18095550000">
              </div>
              <div>
                <label class="form-label">Motivo de visita</label>
                <select class="form-input" id="reg-motivo">
                  <option value="">Seleccionar...</option>
                  <option>Limpieza dental</option>
                  <option>Dolor / Urgencia</option>
                  <option>Consulta general</option>
                  <option>Control ortodoncia</option>
                  <option>Blanqueamiento</option>
                  <option>Otro</option>
                </select>
              </div>
              <button class="btn btn-primary" style="justify-content:center;padding:10px" onclick="registrarPaciente()" id="btn-registrar"><i class="ti ti-user-check"></i>Registrar paciente</button>
            </div>
          </div>
        </div>
      </div>

      <!-- ===== PACIENTES ===== -->
      <div id="tab-pacientes" class="tab-panel">
        <div class="patients-split" id="patients-split">
          <!-- LEFT: Patient List -->
          <div class="patients-list-pane">
            <div class="patients-search">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
                <span style="font-size:12px;font-weight:700;color:var(--text-primary)">Pacientes</span>
                <button class="btn btn-primary btn-sm" onclick="openNewPatientModal()" style="padding:4px 8px;font-size:11px"><i class="ti ti-plus"></i></button>
              </div>
              <input type="text" id="patients-search-input" placeholder="&#128269; Buscar paciente..." oninput="filterPatientsList()" autocomplete="off">
            </div>
            <div class="patients-scroll" id="patients-list-container">
              <div style="text-align:center;padding:24px;color:var(--text-tertiary);font-size:12px"><span class="spinner"></span></div>
            </div>
          </div>
          <!-- RIGHT: Patient Record -->
          <div class="patients-record-pane" id="patients-record-pane">
            <div class="patients-empty" id="patients-no-selection">
              <i class="ti ti-user-heart"></i>
              <span>Selecciona un paciente para ver su expediente</span>
            </div>
            <div id="patients-record-content" style="display:none;flex-direction:column;height:100%;overflow:hidden;display:none">
              <!-- Header -->
              <div class="patient-record-header">
                <div class="patient-record-avatar" id="pr-avatar"></div>
                <div class="patient-record-title">
                  <div class="patient-record-name" id="pr-name">—</div>
                  <div class="patient-record-sub" id="pr-sub">—</div>
                </div>
                <div style="display:flex;gap:8px;margin-left:auto">
                  <button class="btn btn-sm" onclick="openEditPatientModal()" style="font-size:11px"><i class="ti ti-pencil"></i> Editar</button>
                  <a id="pr-wa-link" href="#" target="_blank" class="btn btn-sm" style="background:var(--green-bg);color:var(--green-text);border:1px solid var(--green-border);font-size:11px"><i class="ti ti-brand-whatsapp"></i> Chat</a>
                </div>
              </div>
              <!-- Sub-tabs -->
              <div class="patient-subtabs">
                <button class="patient-subtab active" id="pst-ficha" onclick="switchPatientSubtab('ficha')"><i class="ti ti-id-badge"></i> Ficha</button>
                <button class="patient-subtab" id="pst-historial" onclick="switchPatientSubtab('historial')"><i class="ti ti-notes-medical"></i> Historial</button>
                <button class="patient-subtab" id="pst-recetas" onclick="switchPatientSubtab('recetas')"><i class="ti ti-pill"></i> Recetas</button>
                <button class="patient-subtab" id="pst-laboratorios" onclick="switchPatientSubtab('laboratorios')"><i class="ti ti-microscope"></i> Laboratorios</button>
                <button class="patient-subtab" id="pst-diagnosticos" onclick="switchPatientSubtab('diagnosticos')"><i class="ti ti-stethoscope"></i> Diagnósticos</button>
                <button class="patient-subtab" id="pst-timeline" onclick="switchPatientSubtab('timeline')"><i class="ti ti-timeline"></i> Línea de Tiempo</button>
                <button class="patient-subtab" id="pst-chat" onclick="switchPatientSubtab('chat')"><i class="ti ti-message-dots"></i> Chat WhatsApp</button>
              </div>
              <!-- Sub-tab Contents -->
              <div style="flex:1;overflow:hidden;position:relative">
                <!-- FICHA -->
                <div class="patient-subtab-content active" id="psc-ficha">
                  <div class="patient-info-grid">
                    <div class="patient-info-field"><label>Nombre completo</label><span id="pf-nombre">—</span></div>
                    <div class="patient-info-field"><label>Cédula de Identidad</label><span id="pf-cedula">—</span></div>
                    <div class="patient-info-field"><label>Teléfono / WhatsApp</label><span id="pf-telefono">—</span></div>
                    <div class="patient-info-field"><label>Correo electrónico</label><span id="pf-correo">—</span></div>
                    <div class="patient-info-field" style="grid-column:1/-1"><label>Dirección</label><span id="pf-direccion">—</span></div>
                  </div>
                  <div style="margin-bottom:8px"><span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--text-tertiary)">Total de citas</span></div>
                  <div id="pf-apts-summary" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px"></div>
                </div>
                <!-- HISTORIAL CLÍNICO -->
                <div class="patient-subtab-content" id="psc-historial">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
                    <span style="font-size:12px;font-weight:700;color:var(--text-primary)">Historial clínico general</span>
                    <button class="btn btn-sm btn-primary" onclick="savePatientHistorial()" style="font-size:11px"><i class="ti ti-device-floppy"></i> Guardar</button>
                  </div>
                  <textarea id="p-historial-text" class="form-input" style="width:100%;min-height:200px;font-size:12px;line-height:1.6" placeholder="Antecedentes, alergias, condiciones crónicas, medicación habitual..."></textarea>
                </div>
                <!-- RECETAS -->
                <div class="patient-subtab-content" id="psc-recetas">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                    <span style="font-size:12px;font-weight:700;color:var(--text-primary)">Recetas médicas</span>
                  </div>
                  <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
                    <input type="text" id="rx-medicamento" class="form-input" style="flex:2;min-width:140px;font-size:12px" placeholder="Medicamento y dosis (Ej: Amoxicilina 500mg)">
                    <input type="text" id="rx-instrucciones" class="form-input" style="flex:2;min-width:140px;font-size:12px" placeholder="Instrucciones (Ej: 1 cáp. cada 8 horas x 7 días)">
                    <input type="date" id="rx-fecha" class="form-input" style="flex:1;min-width:110px;font-size:12px">
                    <button class="btn btn-primary btn-sm" onclick="addReceta()" style="font-size:11px"><i class="ti ti-plus"></i> Agregar</button>
                  </div>
                  <div id="recetas-list"></div>
                </div>
                <!-- LABORATORIOS -->
                <div class="patient-subtab-content" id="psc-laboratorios">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                    <span style="font-size:12px;font-weight:700;color:var(--text-primary)">Resultados de laboratorio certificados</span>
                  </div>
                  <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
                    <input type="text" id="lab-tipo" class="form-input" style="flex:2;min-width:140px;font-size:12px" placeholder="Tipo de examen (Ej: Hemograma completo)">
                    <input type="text" id="lab-resultado" class="form-input" style="flex:2;min-width:140px;font-size:12px" placeholder="Resultado o nota">
                    <input type="date" id="lab-fecha" class="form-input" style="flex:1;min-width:110px;font-size:12px">
                    <button class="btn btn-primary btn-sm" onclick="addLaboratorio()" style="font-size:11px"><i class="ti ti-plus"></i> Agregar</button>
                  </div>
                  <div id="labs-list"></div>
                </div>
                <!-- DIAGNÓSTICOS -->
                <div class="patient-subtab-content" id="psc-diagnosticos">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                    <span style="font-size:12px;font-weight:700;color:var(--text-primary)">Diagnósticos clínicos</span>
                  </div>
                  <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap">
                    <input type="text" id="dx-descripcion" class="form-input" style="flex:3;min-width:180px;font-size:12px" placeholder="Diagnóstico (Ej: Caries dental molar inferior izquierdo)">
                    <input type="text" id="dx-codigo" class="form-input" style="flex:1;min-width:80px;font-size:12px" placeholder="CIE-10 (opcional)">
                    <input type="date" id="dx-fecha" class="form-input" style="flex:1;min-width:110px;font-size:12px">
                    <button class="btn btn-primary btn-sm" onclick="addDiagnostico()" style="font-size:11px"><i class="ti ti-plus"></i> Agregar</button>
                  </div>
                  <div id="diagnosticos-list"></div>
                </div>
                <!-- LÍNEA DE TIEMPO -->
                <div class="patient-subtab-content" id="psc-timeline">
                  <div class="timeline-feed" id="patient-timeline"></div>
                </div>
                <!-- CHAT WHATSAPP -->
                <div class="patient-subtab-content" id="psc-chat">
                  <div class="chat-transcript" id="patient-chat-log"><div style="text-align:center;color:var(--text-tertiary);font-size:12px;padding:20px">Selecciona un paciente para ver el historial de conversación</div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ===== MULTI-BOTS ===== -->
      <div id="tab-clientes" class="tab-panel">
        <!-- Bloqueo visual cuando no está autenticado -->
        <div id="multibots-locked-overlay" style="display:none;text-align:center;padding:80px 20px">
          <div style="font-size:48px;margin-bottom:16px">Ã°Å¸â€â€™</div>
          <div style="font-size:16px;font-weight:600;color:var(--text-primary);margin-bottom:8px">Acceso Privado</div>
          <div style="font-size:13px;color:var(--text-secondary);margin-bottom:24px">Esta sección es exclusiva del administrador del sistema.</div>
          <button class="btn btn-primary" onclick="requestMultiBotAccess(document.getElementById('nav-clientes'))"><i class="ti ti-lock-open"></i>Ingresar PIN de acceso</button>
        </div>
        <!-- Contenido real (oculto hasta autenticación) -->
        <div id="multibots-content" style="display:none">
        <div class="section-header">
          <span class="section-title">Panel Multi-Bots</span>
          <div style="display:flex;gap:8px">
            <button class="btn btn-primary btn-sm" onclick="toggleNewClientForm()"><i class="ti ti-plus"></i>Nuevo Bot</button>
            <button class="btn btn-danger btn-sm" onclick="lockMultiBotsSession()"><i class="ti ti-lock"></i>Cerrar Sesión Bot</button>

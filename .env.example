# ═══════════════════════════════════════════════
# CONFIGURACIÓN DEL BOT WHATSAPP IA
# ═══════════════════════════════════════════════

# API Key de Groq (gratis en https://console.groq.com/keys)
GROQ_API_KEY=PEGA-TU-API-KEY-DE-GROQ-AQUI

# Puerto del servidor dashboard
PORT=3000

# Plan activo: basico | estandar | completo
PLAN_ACTIVO=completo

# Modelo de IA (Llama 3.3 70B — gratis y rápido)
AI_MODEL=llama-3.3-70b-versatile

# Número del dueño del negocio (para recibir notificaciones de citas)
# Formato: código de país + número, sin guiones ni espacios
# Ejemplo: 18095551234
OWNER_PHONE=PEGA-EL-NUMERO-DEL-DUEÑO-AQUI
